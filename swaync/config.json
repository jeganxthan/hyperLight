{
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "overlay",
  "layer-shell": true,
  "cssPriority": "application",
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 0,
  "control-center-margin-right": 8,
  "control-center-margin-left": 0,
  "notification-icon-size": 48,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 6,
  "timeout-low": 3,
  "timeout-critical": 0,
  "fit-to-screen": false,
  "control-center-width": 340,
  "control-center-height": 700,
  "notification-window-width": 360,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 220,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,

  "widgets": [
    "title",
    "dnd",
    "mpris",
    "volume",
    "backlight",
    "buttons-grid",
    "notifications"
  ],

  "widget-config": {

    "title": {
      "text": "Control Center",
      "clear-all-button": true,
      "button-text": "󰃢  Clear"
    },

    "dnd": {
      "text": "Do Not Disturb"
    },

    "mpris": {
      "image-size": 56,
      "image-radius": 8
    },

    "volume": {
      "label": "󰕾",
      "show-per-app": false
    },

    "backlight": {
      "label": "󰃝"
    },

    "buttons-grid": {
      "actions": [
        {
          "label": "󰖩",
          "command": "bash -c 'if nmcli radio wifi | grep -q enabled; then nmcli radio wifi off; else nmcli radio wifi on; fi'",
          "tooltip": "Wi-Fi"
        },
        {
          "label": "󰂱",
          "command": "bash -c 'if bluetoothctl show | grep -q \"Powered: yes\"; then bluetoothctl power off; else bluetoothctl power on; fi'",
          "tooltip": "Bluetooth"
        },
        {
          "label": "󰀝",
          "command": "bash -c 'if rfkill list | grep -q \"yes\"; then rfkill unblock all; else rfkill block all; fi'",
          "tooltip": "Airplane"
        },
        {
          "label": "󰌾",
          "command": "hyprlock",
          "tooltip": "Lock"
        },
        {
          "label": "󰤄",
          "command": "systemctl suspend",
          "tooltip": "Suspend"
        },
        {
          "label": "󰍺",
          "command": "hyprctl dispatch dpms toggle",
          "tooltip": "Display"
        }
      ]
    },

    "notifications": {}
  }
}
