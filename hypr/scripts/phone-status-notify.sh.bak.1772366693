#!/usr/bin/env bash

last=""
refresh_ticks=0

while true; do
  battery="$(cat /tmp/phonebridge_battery 2>/dev/null)"
  status="$(cat /tmp/phonebridge_status 2>/dev/null)"

  if [[ -n "$battery" && -n "$status" && "$status" != "󰤿 --" ]]; then
    device="${status#󰤿 }"
    msg="$device|$battery"
    refresh_ticks=$((refresh_ticks + 1))

    # Re-publish every 60s even if unchanged (helps after clear/reload)
    if [[ "$msg" != "$last" || $refresh_ticks -ge 6 ]]; then
      /usr/bin/notify-send \
        --app-name "PhoneBridge" \
        --category "phonebridge-status" \
        --urgency low \
        --expire-time 0 \
        --hint string:x-canonical-private-synchronous:phone-status \
        "󰤿  $device" \
        "$battery"
      last="$msg"
      refresh_ticks=0
    fi
  else
    refresh_ticks=$((refresh_ticks + 1))
    if [[ "$last" != "offline" || $refresh_ticks -ge 6 ]]; then
      /usr/bin/notify-send \
        --app-name "PhoneBridge" \
        --category "phonebridge-status" \
        --urgency low \
        --expire-time 0 \
        --hint string:x-canonical-private-synchronous:phone-status \
        "󰤿  PhoneBridge" \
        "Disconnected"
      last="offline"
      refresh_ticks=0
    fi
  fi

  sleep 10
done
