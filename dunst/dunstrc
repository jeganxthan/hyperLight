[global]
    monitor = 0
    follow = mouse
    width = 360
    height = 140
    origin = top-right
    offset = 14x14
    scale = 0
    notification_limit = 8
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 10
    horizontal_padding = 12
    text_icon_padding = 8
    frame_width = 2
    frame_color = "#5a5a5a"
    separator_color = frame
    corner_radius = 10
    idle_threshold = 120
    font = JetBrainsMono Nerd Font 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    icon_position = left
    min_icon_size = 20
    max_icon_size = 48
    sticky_history = yes
    history_length = 20
    browser = xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    ignore_dbusclose = false
    sort = yes

[urgency_low]
    timeout = 3
    background = "#0f0f0f"
    foreground = "#d9d9d9"
    frame_color = "#4b4b4b"

[urgency_normal]
    timeout = 6
    background = "#0b0b0b"
    foreground = "#efefef"
    frame_color = "#666666"

[urgency_critical]
    timeout = 0
    background = "#120f0f"
    foreground = "#ffffff"
    frame_color = "#8a8a8a"
