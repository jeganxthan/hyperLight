# =========================
# Whitelist Dotfiles
# =========================

# Ignore everything by default
*

# Allow the specific config directories
!/hypr/
!/waybar/
!/swaync/
!/rofi/
!/kitty/
!/ags/
!/wofi/
!/wlogout/
!/cava/
!/qt6ct/

# Allow root level config files
!.gitignore
!README.md

# Ignore potential sensitive files within those directories
**/login.conf
**/credentials*
**/*.log
**/*.tmp
**/*.cache
**/*.pid
**/*.lock
**/*.bak
**/*.old
**/*.swp
**/*.swo
**/secrets.env

# =========================
# System / OS
# =========================
.DS_Store
Thumbs.db
