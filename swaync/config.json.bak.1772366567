{
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "overlay",
  "layer-shell": true,
  "cssPriority": "user",
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 0,
  "control-center-margin-right": 8,
  "control-center-margin-left": 0,
  "notification-icon-size": 44,
  "notification-body-image-height": 80,
  "notification-body-image-width": 160,
  "timeout": 5,
  "timeout-low": 3,
  "timeout-critical": 0,
  "fit-to-screen": false,
  "control-center-width": 320,
  "control-center-height": 720,
  "notification-window-width": 340,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": false,

  "widgets": [
    "title",
    "dnd",
    "volume",
    "backlight",
    "buttons-grid",
    "notifications"
  ],

  "widget-config": {

    "title": {
      "text": "Control Center",
      "clear-all-button": true,
      "button-text": "󰃢  Clear"
    },

    "dnd": {
      "text": "Do Not Disturb"
    },

    "volume": {
      "label": "󰕾",
      "show-per-app": false
    },

    "backlight": {
      "label": "󰃝"
    },

    "buttons-grid": {
      "actions": [
        {
          "label": "󰖩",
          "command": "bash -c 'STATE=$(nmcli -t -f WIFI g); if echo \"$STATE\" | grep -q \"enabled\"; then nmcli radio wifi off; else nmcli radio wifi on; fi'",
          "update-command": "bash -c 'nmcli -t -f WIFI g | grep -q enabled && echo active || echo inactive'",
          "active": false,
          "tooltip": "Wi-Fi"
        },
        {
          "label": "󰂱",
          "command": "bash -c 'if bluetoothctl show | grep -q \"Powered: yes\"; then bluetoothctl power off; else bluetoothctl power on; fi'",
          "update-command": "bash -c 'bluetoothctl show | grep -q \"Powered: yes\" && echo active || echo inactive'",
          "active": false,
          "tooltip": "Bluetooth"
        },
        {
          "label": "󰀝",
          "command": "bash -c 'if rfkill list | grep -q \"blocked: yes\"; then rfkill unblock all; else rfkill block all; fi'",
          "update-command": "bash -c 'rfkill list | grep -q \"blocked: yes\" && echo active || echo inactive'",
          "active": false,
          "tooltip": "Airplane"
        },
        {
          "label": "󰌾",
          "command": "hyprlock",
          "tooltip": "Lock"
        },
        {
          "label": "󰤄",
          "command": "systemctl suspend",
          "tooltip": "Suspend"
        }
      ]
    },

    "notifications": {}
  }
}